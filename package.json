{
  "name": "arkts-lsp",
  "version": "0.1.0",
  "description": "ArkTS language server MVP",
  "license": "MIT",
  "private": false,
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "arkts-lsp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run"
  },
  "keywords": [
    "arkts",
    "lsp",
    "language-server",
    "harmonyos"
  ],
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  }
}
